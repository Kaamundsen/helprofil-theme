{%- comment -%}
  Når tema har Pipedrive API-token: kontaktskjema sendes først til Pipedrive
  (person + deal + notat), deretter POST til Shopifys vanlige contact-endepunkt
  slik at e-postvarsel fortsatt fungerer.
{%- endcomment -%}
{% liquid
  assign pd_pipeline = settings.pipedrive_pipeline_id | default: 2 | plus: 0
  assign pd_stage = settings.pipedrive_stage_id | default: 6 | plus: 0
%}
{% if settings.pipedrive_api_token != blank %}
  <script>
    (function () {
      var TOKEN = {{ settings.pipedrive_api_token | json }};
      var BASE = 'https://api.pipedrive.com/v1';
      var PIPELINE_ID = {{ pd_pipeline }};
      var STAGE_ID = {{ pd_stage }};
      var SUCCESS_TEXT = {{ 'blocks.contact_form.post_success' | t | json }};

      function shopifyPostLooksSuccessful(res) {
        if (res.ok) return true;
        if (res.status === 302 || res.status === 301) return true;
        if (res.type === 'opaqueredirect') return true;
        return false;
      }

      function qs(form, name) {
        var v = new FormData(form).get(name);
        return v != null ? String(v).trim() : '';
      }

      document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.contact-form__form').forEach(function (form) {
          if (form.dataset.pipedriveBound) return;
          form.dataset.pipedriveBound = 'true';

          form.addEventListener('submit', async function (e) {
            e.preventDefault();

            var wrap = form.closest('.contact-form');
            if (wrap) {
              wrap.querySelectorAll('.contact-form__success').forEach(function (el) {
                el.remove();
              });
              wrap.querySelectorAll('.contact-form__error').forEach(function (el) {
                el.remove();
              });
            }

            var submitBtn = form.querySelector('[type="submit"]');
            if (submitBtn) {
              submitBtn.disabled = true;
              submitBtn.setAttribute('aria-busy', 'true');
            }

            var name = qs(form, 'contact[name]');
            var email = qs(form, 'contact[email]');
            var phone = qs(form, 'contact[phone]');
            var body = qs(form, 'contact[body]');

            if (!email) {
              if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.removeAttribute('aria-busy');
              }
              return;
            }

            try {
              var personPayload = {
                name: name || email,
                email: [{ value: email, primary: true }],
              };
              if (phone) personPayload.phone = [{ value: phone, primary: true }];

              var personRes = await fetch(BASE + '/persons?api_token=' + encodeURIComponent(TOKEN), {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(personPayload),
              });
              if (!personRes.ok) throw new Error('Person: ' + personRes.status);
              var person = await personRes.json();
              if (!person.success) throw new Error('Person: ' + JSON.stringify(person));
              var personId = person.data.id;

              var dealTitle = 'Kontaktskjema \u2013 ' + (name || email);
              var dealId = null;
              var dealRes = await fetch(BASE + '/deals?api_token=' + encodeURIComponent(TOKEN), {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  title: dealTitle,
                  person_id: personId,
                  pipeline_id: PIPELINE_ID,
                  stage_id: STAGE_ID,
                }),
              });
              var deal = await dealRes.json();
              if (dealRes.ok && deal.success && deal.data && deal.data.id) {
                dealId = deal.data.id;
              } else {
                console.warn('Pipedrive deal (kontakt):', dealRes.status, deal);
              }

              var noteContent = '<b>Kilde:</b> Kontaktskjema (nettbutikk)<br>';
              noteContent += '<b>Navn:</b> ' + (name || '-') + '<br>';
              noteContent += '<b>E-post:</b> ' + email + '<br>';
              if (phone) noteContent += '<b>Telefon:</b> ' + phone + '<br>';
              if (body) noteContent += '<br><b>Melding:</b><br>' + body.replace(/\n/g, '<br>');

              var notePayload = { content: noteContent, person_id: personId };
              if (dealId) notePayload.deal_id = dealId;
              var noteRes = await fetch(BASE + '/notes?api_token=' + encodeURIComponent(TOKEN), {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(notePayload),
              });
              if (!noteRes.ok) {
                var noteErr = await noteRes.text();
                console.warn('Pipedrive note (kontakt):', noteRes.status, noteErr);
              }

              var action = form.getAttribute('action') || window.location.pathname;
              var shopRes = await fetch(action, {
                method: 'POST',
                body: new FormData(form),
                credentials: 'same-origin',
                redirect: 'manual',
                headers: { Accept: 'text/html' },
              });
              if (!shopifyPostLooksSuccessful(shopRes)) {
                console.warn('Shopify kontakt-POST:', shopRes.status, shopRes.type);
                /* Person + notat ligger i Pipedrive; vis likevel takk */
              }

              form.style.display = 'none';
              var ok = document.createElement('div');
              ok.className = 'contact-form__success';
              ok.setAttribute('tabindex', '-1');
              ok.textContent = SUCCESS_TEXT;
              if (wrap) wrap.insertBefore(ok, wrap.firstChild);
              else form.parentNode.insertBefore(ok, form);
              ok.focus();
            } catch (err) {
              console.error('Kontakt / Pipedrive:', err);
              alert('Kunne ikke sende skjema. Prøv igjen eller ring oss.');
              if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.removeAttribute('aria-busy');
              }
            }
          });
        });
      });
    })();
  </script>
{% endif %}
