<div class="foresporsel-page page-width">
  <div class="foresporsel-layout">

    <div class="foresporsel-left">
      <div class="foresporsel-logo">{{ shop.name }}</div>

      {%- form 'contact', id: 'foresporsel-form' -%}

        {% if form.posted_successfully? %}
          <div class="foresporsel-success">
            <p>Takk! Vi har mottatt forespørselen din og tar kontakt snart.</p>
          </div>
        {% endif %}

        <div class="foresporsel-section">
          <h2 class="foresporsel-section-title">Kontakt</h2>
          <div class="foresporsel-field">
            <input
              type="email"
              name="contact[E-post]"
              id="foresporsel-email"
              placeholder="E-post"
              autocomplete="email"
              required
            >
          </div>
          <div class="foresporsel-field">
            <input
              type="tel"
              name="contact[Telefon]"
              id="foresporsel-phone"
              placeholder="Mobiltelefonnummer (valgfritt)"
              autocomplete="tel"
            >
          </div>
        </div>

        <div class="foresporsel-section">
          <h2 class="foresporsel-section-title">Levering</h2>
          <div class="foresporsel-field">
            <select name="contact[Land]" id="foresporsel-country" autocomplete="country-name">
              <option value="Norge" selected>Norge</option>
              <option value="Sverige">Sverige</option>
              <option value="Danmark">Danmark</option>
              <option value="Finland">Finland</option>
              <option value="Annet">Annet</option>
            </select>
          </div>
          <div class="foresporsel-field-row">
            <div class="foresporsel-field">
              <input
                type="text"
                name="contact[Fornavn]"
                id="foresporsel-firstname"
                placeholder="Fornavn (valgfritt)"
                autocomplete="given-name"
              >
            </div>
            <div class="foresporsel-field">
              <input
                type="text"
                name="contact[Etternavn]"
                id="foresporsel-lastname"
                placeholder="Etternavn"
                required
                autocomplete="family-name"
              >
            </div>
          </div>
          <div class="foresporsel-field">
            <input
              type="text"
              name="contact[Adresse]"
              id="foresporsel-address"
              placeholder="Adresse"
              autocomplete="street-address"
            >
          </div>
          <div class="foresporsel-field">
            <input
              type="text"
              name="contact[Leilighet]"
              id="foresporsel-apt"
              placeholder="Leilighet, etasje osv. (valgfritt)"
              autocomplete="address-line2"
            >
          </div>
          <div class="foresporsel-field-row">
            <div class="foresporsel-field">
              <input
                type="text"
                name="contact[Postnummer]"
                id="foresporsel-zip"
                placeholder="Postnummer"
                autocomplete="postal-code"
              >
            </div>
            <div class="foresporsel-field">
              <input
                type="text"
                name="contact[By]"
                id="foresporsel-city"
                placeholder="By"
                autocomplete="address-level2"
              >
            </div>
          </div>
        </div>

        <div class="foresporsel-section">
          <h2 class="foresporsel-section-title">Melding (valgfritt)</h2>
          <div class="foresporsel-field">
            <textarea
              name="contact[Melding]"
              id="foresporsel-message"
              placeholder="Legg til en melding til oss..."
              rows="3"
            ></textarea>
          </div>
        </div>

        <input type="hidden" name="contact[Produkter]" id="foresporsel-cart-hidden">

        <button type="submit" class="foresporsel-submit button">
          Send forespørsel
        </button>

      {%- endform -%}
    </div>

    <div class="foresporsel-right">
      <div class="foresporsel-cart" id="foresporsel-cart-items">
        <p class="foresporsel-cart-loading">Laster handlekurv...</p>
      </div>
    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    fetch('/cart.js')
      .then(function (res) { return res.json(); })
      .then(function (cart) {
        var container = document.getElementById('foresporsel-cart-items');
        var hidden = document.getElementById('foresporsel-cart-hidden');

        if (!cart.items || cart.items.length === 0) {
          container.innerHTML = '<p class="foresporsel-cart-empty">Handlekurven er tom.</p>';
          return;
        }

        var lines = [];
        var html = '';

        cart.items.forEach(function (item) {
          var variantInfo = item.variant_title && item.variant_title !== 'Default Title'
            ? ' — ' + item.variant_title
            : '';
          lines.push(item.quantity + 'x ' + item.product_title + variantInfo);

          html += '<div class="foresporsel-cart-item">';
          html += '<div class="foresporsel-cart-item-img">';
          if (item.image) {
            html += '<img src="' + item.image + '" alt="' + item.product_title + '">';
          }
          html += '</div>';
          html += '<div class="foresporsel-cart-item-details">';
          html += '<p class="foresporsel-cart-item-title">' + item.product_title + '</p>';
          if (variantInfo) {
            html += '<p class="foresporsel-cart-item-variant">' + item.variant_title + '</p>';
          }
          html += '<p class="foresporsel-cart-item-qty">Antall: ' + item.quantity + '</p>';
          html += '</div>';
          html += '</div>';
        });

        container.innerHTML = html;
        hidden.value = lines.join('\n');
      })
      .catch(function () {
        document.getElementById('foresporsel-cart-items').innerHTML =
          '<p>Kunne ikke laste handlekurv.</p>';
      });
  });
</script>

{% stylesheet %}
  .foresporsel-page {
    padding-block: 40px 80px;
  }

  .foresporsel-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  @media screen and (max-width: 749px) {
    .foresporsel-layout {
      grid-template-columns: 1fr;
    }

    .foresporsel-right {
      order: -1;
    }
  }

  .foresporsel-logo {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 32px;
  }

  .foresporsel-section {
    margin-bottom: 28px;
  }

  .foresporsel-section-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .foresporsel-field {
    margin-bottom: 8px;
  }

  .foresporsel-field input,
  .foresporsel-field select,
  .foresporsel-field textarea {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid var(--color-border);
    border-radius: var(--style-border-radius-inputs, 4px);
    font-size: 1rem;
    font-family: inherit;
    background: var(--color-background);
    color: var(--color-foreground);
    box-sizing: border-box;
  }

  .foresporsel-field input:focus,
  .foresporsel-field select:focus,
  .foresporsel-field textarea:focus {
    outline: 2px solid var(--color-primary);
    outline-offset: -1px;
    border-color: var(--color-primary);
  }

  .foresporsel-field textarea {
    resize: vertical;
  }

  .foresporsel-field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  .foresporsel-submit {
    width: 100%;
    margin-top: 8px;
  }

  .foresporsel-success {
    background: #e6f4ea;
    border: 1px solid #a8d5b5;
    border-radius: 4px;
    padding: 16px;
    margin-bottom: 24px;
    color: #2d6a4f;
  }

  .foresporsel-right {
    position: sticky;
    top: 20px;
    background: #f5f5f5;
    border-radius: 8px;
    padding: 28px;
  }

  .foresporsel-cart-item {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 16px;
    align-items: center;
    padding-block: 14px;
    border-bottom: 1px solid var(--color-border);
  }

  .foresporsel-cart-item:last-child {
    border-bottom: none;
  }

  .foresporsel-cart-item-img img {
    width: 64px;
    height: 64px;
    object-fit: contain;
    border-radius: 4px;
    background: #fff;
  }

  .foresporsel-cart-item-title {
    font-size: 0.95rem;
    font-weight: 500;
    margin: 0 0 4px;
  }

  .foresporsel-cart-item-variant {
    font-size: 0.85rem;
    color: var(--color-foreground-secondary, #666);
    margin: 0 0 4px;
  }

  .foresporsel-cart-item-qty {
    font-size: 0.85rem;
    color: var(--color-foreground-secondary, #666);
    margin: 0;
  }

  .foresporsel-cart-loading,
  .foresporsel-cart-empty {
    font-size: 0.95rem;
    color: var(--color-foreground-secondary, #666);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Forespørsel",
  "tag": "section",
  "settings": []
}
{% endschema %}
